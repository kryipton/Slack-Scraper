# Copy this to .env and fill in your values
# Never commit .env to git

# ----------------------------------------------------------------
# Google Sheets / Drive (for deliverable exports)
# ----------------------------------------------------------------
# Path to your Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json
# Path to the generated OAuth token (auto-created on first auth)
GOOGLE_TOKEN_PATH=token.json
# Spreadsheet ID to write scraped data into (leave blank to create new)
TARGET_SPREADSHEET_ID=

# ----------------------------------------------------------------
# Slack (optional – only needed for API-based approaches)
# ----------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_USER_TOKEN=xoxp-...

# ----------------------------------------------------------------
# Misc
# ----------------------------------------------------------------
# Local output directory for intermediates (should match .tmp/)
TMP_DIR=.tmp
